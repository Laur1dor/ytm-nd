# Скопируй в .env и заполни. Реальный .env лежит только на сервере (в git не коммитим).

# Ссылка на ПУБЛИЧНЫЙ плейлист YouTube Music (обязательно)
PLAYLIST_URL=https://music.youtube.com/playlist?list=XXXXXXXXXXXXXXXXXX

# Ключ YouTube Data API v3 — НАДЁЖНЫЙ способ получать полный список треков
# (cookies протухают за часы, ключ — нет). Создаётся бесплатно в Google Cloud Console:
# APIs & Services -> Library -> "YouTube Data API v3" -> Enable -> Credentials -> API key.
# Если пусто — используется резерв через yt-dlp + data/cookies.txt.
YT_API_KEY=

# Как часто проверять плейлист, в секундах (14400 = 4 часа)
INTERVAL_SECONDS=14400

# Имя подпапки внутри /music, куда складывать треки
MUSIC_SUBDIR=YTM

# Группировка в Navidrome: все треки как один альбом (чтобы не было сотен одиночных)
ALBUM_NAME=YTM
ALBUM_ARTIST=YouTube Music

# Путь к музыке на ХОСТЕ (монтируется в /music). По умолчанию /mnt/Music (CIFS-шара).
MUSIC_HOST_PATH=/mnt/Music

# Хранилище: true — гард «писать только на сетевую шару» (защита от записи на локальный
# диск, если шара отвалилась). Для локального/иного хранилища поставь false и укажи
# MUSIC_HOST_PATH на локальную папку.
REQUIRE_SHARE=true

# Опциональное зеркало в S3/удалённое хранилище через rclone (напр. "s3:bucket/music").
# Пусто = выключено. Конфиг rclone клади в data/rclone.conf.
RCLONE_REMOTE=

# Таймзона
TZ=Europe/Moscow
